{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",

    "strict": true,

    "skipLibCheck": true,

    "esModuleInterop": true,

    "moduleResolution": "node",

    "ignoreDeprecations": "6.0",

    "types": ["node"],

    "baseUrl": ".",

    "paths": {
      "@pages/*": ["pages/*"],
      "@fixtures/*": ["fixtures/*"],
      "@tests/*": ["tests/*"],
      "@configs/*": ["configs/*"]
    }
  },

  "include": ["./**/*.ts"],

  "exclude": [
    "node_modules",
    "configs/appium",
    "drivers",
    "fixtures/mobile",
    "pages/mobile",
    "steps/android",
    "steps/ios",
    "tests/android",
    "tests/ios"
  ]
}